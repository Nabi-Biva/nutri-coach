<div class="container py-5" style="max-width: 800px;">
  <%= link_to "← Retour aux recettes",
        chat_recipes_path(@recipe.chat),
        class: "btn btn-outline-secondary mb-4" %>

  <div class="card border-0 shadow p-5" style="border-radius: 16px;">
    <div class="fs-1 mb-3">🥗</div>
    <h1 class="fw-bold mb-1"><%= @recipe.name %></h1>

   <% if @recipe.updated_at != @recipe.created_at %>
    <p class="text-muted small mb-4">Modifiée le <%= @recipe.updated_at.strftime("%d/%m/%Y") %></p>
   <% end %>

    <hr>

    <div class="mt-4">
      <% markdown = Redcarpet::Markdown.new(Redcarpet::Render::HTML) %>
      <%= markdown.render(@recipe.content).html_safe %>
    </div>
  </div>
</div>
