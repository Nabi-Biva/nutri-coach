<div class="container py-5">
  <h1 class="fw-bold mb-4">🍽️ Mes recettes</h1>
  <div class="row g-4">
    <% @recipes.each do |recipe| %>
      <div class="col-md-4">
        <div class="card border-0 shadow h-100" style="border-radius: 16px;">
          <div class="card-body p-4">
            <div class="fs-2 mb-2">🥗</div>
            <h5 class="fw-bold"><%= recipe.name %></h5>
          </div>
          <div class="card-footer border-0 bg-transparent pb-4 px-4">
            <%= link_to "Voir la recette", chat_recipe_path(recipe.chat, recipe), class: "btn w-100 text-white fw-bold", style: "background-color: #2d6a4f;" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
