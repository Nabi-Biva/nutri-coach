<div class="container mt-4" style="max-width: 800px;">
  <%= render partial: "chats/header", locals: { chat: @chat } %>

  <div id="messages" class="mb-4" style="min-height: 200px;">
    <%= render @messages %>
  </div>

  <%= turbo_frame_tag "new_message_form" do %>
    <%= simple_form_for [@chat, @message] do |f| %>
      <%= f.input :content, label: "Votre message", required: false, input_html: { rows: 3 } %>
      <%= f.button :submit, "Envoyer", class: "btn btn-success" %>
    <% end %>
  <% end %>
</div>
