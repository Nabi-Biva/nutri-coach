<div class="d-flex" style="height: 100vh;">
  <div class="d-flex flex-column" style="width: 260px; background-color: #2d6a4f;">

    <!-- Header -->
    <div class="p-3 border-bottom border-white border-opacity-25" style="border-top: 10px solid rgba(255,255,255,0.25) !important;">>
      <div class="d-flex align-items-center gap-2 mb-3">
        <!-- <span style="font-size: 20px;">🥗</span> -->
        <!-- <span class="text-white fw-500 fs-6">NutriCoach</span> -->
      </div>
      <%= button_to chats_path, method: :post, class: "btn w-100 d-flex align-items-center gap-2 fw-medium text-white border-0",
    style: "background-color: #40c074;",
    onmouseover: "this.style.backgroundColor='#36a862'",
    onmouseout: "this.style.backgroundColor='#40c074'" do %>
  <i class="bi bi-plus-lg"></i>
  <span class="text-white">Nouveau chat</span>
<% end %>
    </div>

    <!-- Section label -->
    <div class="px-3 pt-3 pb-1">
      <small class="text-uppercase text-white-50" style="font-size: 11px; letter-spacing: 0.06em;">
        Mes chats
      </small>
    </div>

    <!-- Chat list -->
    <div class="flex-grow-1 overflow-auto px-2 pb-3" id="chatList">
      <% @chats.each do |chat| %>
        <a href="<%= chat_path(chat) %>"
          class="d-flex align-items-center gap-2 px-2 py-2 rounded text-decoration-none text-white mb-1 chat-link <%= 'active-chat' if chat == @chat %>">
          <i class="bi bi-chat text-white-50"></i>
          <span class="text-truncate flex-grow-1 small"><%= chat.title %></span>
          <div class="chat-actions d-none gap-1">
            <button class="btn btn-sm p-0 px-1 text-white-50" onclick="event.stopPropagation()">
              <i class="bi bi-pencil" style="font-size:12px;"></i>
            </button>
            <button class="btn btn-sm p-0 px-1 text-white-50" onclick="event.stopPropagation()">
              <i class="bi bi-trash" style="font-size:12px;"></i>
            </button>
          </div>
      <% end %>
        </a>
    </div>

    <!-- Footer -->
    <div class="p-3 border-top border-white border-opacity-25 d-flex align-items-center gap-2">
      <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-medium"
           style="width:32px; height:32px; background:rgba(255,255,255,0.18); font-size:12px; flex-shrink:0;">
        <%= current_user.first_name[0] %><%= current_user.last_name[0] %>
      </div>
      <div class="flex-grow-1">
        <div class="text-white small fw-medium"><%= current_user.first_name %> <%= current_user.last_name %></div>
        <!-- <div class="text-white-50" style="font-size:11px;">Mon profil</div> -->
        <div><a href="<%= current_user.profile.persisted? ? profile_path(current_user.profile) : new_profile_path %>" class="btn btn-outline-light btn-sm">Mon profil</a></div>
      <button class="btn p-1 text-white-50">
        <i class="bi bi-gear"></i>
      </button>
    </div>
  </div>

