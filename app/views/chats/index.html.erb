
<div class="d-flex" style="height: 100vh;">
  <div class="d-flex flex-column" style="width: 260px; background-color: #2d6a4f;">

    <!-- Header -->
    <div class="p-3 border-bottom border-white border-opacity-25" style="border-top: 10px solid rgba(255,255,255,0.25) !important;">
      <div class="d-flex align-items-center gap-2 mb-3">
        <!-- <span style="font-size: 20px;">🥗</span> -->
        <!-- <span class="text-white fw-500 fs-6">NutriCoach</span> -->
      </div>
      <%= button_to chats_path, method: :post, class: "btn w-100 d-flex align-items-center gap-2 fw-medium text-white border-0",
    style: "background-color: #40c074;",
    onmouseover: "this.style.backgroundColor='#36a862'",
    onmouseout: "this.style.backgroundColor='#40c074'" do %>
  <i class="fa-solid fa-plus"></i>
  <span class="text-white">Nouveau chat</span>
<% end %>
    </div>

    <!-- Section label -->
    <div class="px-3 pt-3 pb-1">
      <small class="text-uppercase text-white-50" style="font-size: 11px; letter-spacing: 0.06em;">
        Mes chats
      </small>
    </div>

    <!-- Chat list -->
    <div class="flex-grow-1 overflow-auto px-2 pb-3" id="chatList">
      <% @chats.each do |chat| %>
        <div class="d-flex align-items-center gap-2 px-2 py-2 rounded mb-1 chat-link <%= 'active-chat' if chat == @chat %>">
          <a href="<%= chat_path(chat) %>"
             class="d-flex align-items-center gap-2 flex-grow-1 text-decoration-none text-white"
             style="min-width: 0;">
            <i class="fa-solid fa-comment text-white-50"></i>
            <span class="text-truncate small" id="chat-title-<%= chat.id %>"><%= chat.title %></span>
          </a>
          <div class="chat-actions d-flex gap-1">
            <button class="btn btn-sm p-0 px-1 text-white-50"
                    onclick="event.stopPropagation();var t=prompt('Nouveau nom :','<%= j chat.title %>');if(t&&t.trim()){fetch('<%= chat_path(chat) %>',{method:'PATCH',headers:{'Content-Type':'application/json','X-CSRF-Token':document.querySelector('[name=csrf-token]').content,'Accept':'text/vnd.turbo-stream.html'},body:JSON.stringify({chat:{title:t.trim()}})}).then(function(r){return r.text()}).then(function(html){if(html){Turbo.renderStreamMessage(html)}})}">
              <i class="fa-solid fa-pen" style="font-size:12px;"></i>
            </button>
            <%= button_to chat_path(chat), method: :delete,
                  class: "btn btn-sm p-0 px-1 text-white-50",
                  form_class: "d-inline",
                  data: { turbo_confirm: "Supprimer ce chat ?" } do %>
              <i class="fa-solid fa-trash" style="font-size:12px;"></i>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Footer -->
    <div class="p-3 border-top border-white border-opacity-25 d-flex align-items-center justify-content-center gap-2 position-fixed bottom-0"
      style="width: 260px; background-color: #2d6a4f;">

      <!-- Avatar -->
      <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-medium"
        style="width:32px; height:32px; background:rgba(255,255,255,0.18); font-size:12px; flex-shrink:0;">
        <%= current_user.first_name[0] %><%= current_user.last_name[0] %>
      </div>

      <!-- Nom utilisateur -->
      <div class="text-white small fw-medium">
        <%= current_user.first_name %>
        <%= current_user.last_name %>
      </div>    </div>
  </div>
</div>
