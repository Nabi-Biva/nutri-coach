<%# <h1>Pages#home</h1>
<p>Find me in app/views/pages/home.html.erb</p> %>


<div class="d-flex align-items-center justify-content-center text-center text-white py-5"
     style="background-image: linear-gradient(rgba(0,0,0,0.45), rgba(0,0,0,0.45)),
            url('https://images.unsplash.com/photo-1490645935967-10de6ba17061?w=1600');
            background-size: cover;
            background-position: center;
            min-height: 90vh;">
<div>
    <p class="text-uppercase fw-bold mb-2" style="letter-spacing: 3px; color: #74c69d;">Coach Nutritionnel IA</p>
    <h1 class="display-2 fw-bold mb-3">🥗 NutriCoach</h1>
    <p class="lead mb-5 mx-auto" style="max-width: 500px;">Ton coach nutritionnel personnalisé</p>
    <% if user_signed_in? %>
      <a href="<%= chats_path %>" class="btn btn-success btn-lg px-5 py-3 me-2">Voir mes chats</a>
    <% else %>
      <a href="<%= new_user_registration_path %>" class="btn btn-success btn-lg px-5 py-3 me-2">Commencer gratuitement</a>
      <a href="<%= new_user_session_path %>" class="btn btn-outline-light btn-lg px-5 py-3">Se connecter</a>
    <% end %>
  </div>
</div>


<div style="background-color: #2d6a4f;">
  <div class="container py-4">
    <div class="row text-center text-white">
      <div class="col-md-4 py-2">
        <h2 class="fw-bold mb-0">🧑‍🤝‍🧑 1000+</h2>
        <p class="mb-0 opacity-75">Utilisateurs actifs</p>
      </div>
      <div class="col-md-4 py-2">
        <h2 class="fw-bold mb-0">🍽️ 500+</h2>
        <p class="mb-0 opacity-75">Recettes générées</p>
      </div>
      <div class="col-md-4 py-2">
        <h2 class="fw-bold mb-0">⭐ 4.9/5</h2>
        <p class="mb-0 opacity-75">Satisfaction utilisateurs</p>
      </div>
    </div>
  </div>
</div>


<div class="container py-5">
  <h2 class="text-center fw-bold mb-5">Pourquoi NutriCoach ?</h2>
  <div class="row text-center g-4">
    <div class="col-md-4">
      <div class="card border-0 shadow p-4 h-100" style="border-radius: 16px;">
        <div class="fs-1 mb-3">🎯</div>
        <h5 class="fw-bold">Objectifs personnalisés</h5>
        <p class="text-muted">L'IA adapte ses conseils selon ton profil, tes objectifs et tes allergies.</p>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card border-0 shadow p-4 h-100" style="border-radius: 16px; background: #2d6a4f;">
        <div class="fs-1 mb-3">💬</div>
        <h5 class="fw-bold text-white">Coach 24h/24</h5>
        <p style="color: #b7e4c7;">Pose toutes tes questions nutrition à ton coach IA à tout moment.</p>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card border-0 shadow p-4 h-100" style="border-radius: 16px;">
        <div class="fs-1 mb-3">🍽️</div>
        <h5 class="fw-bold">Recettes adaptées</h5>
        <p class="text-muted">Reçois des recettes selon tes allergies et ton style de vie.</p>
      </div>
    </div>
  </div>
</div>


<div class="text-center py-5" style="background-color: #f8f9fa;">
  <h2 class="fw-bold mb-3">Prêt à transformer ton mode de vie ?</h2>
  <p class="text-muted mb-4">Rejoins NutriCoach et commence ton parcours nutritionnel dès aujourd'hui.</p>
  <a href="<%= new_user_registration_path %>" class="btn btn-success btn-lg px-5 py-3">
    Commencer gratuitement 🚀
  </a>
</div>


<footer class="text-center py-4" style="background-color: #2d6a4f;">
  <p class="text-white mb-0 opacity-75">© 2026 NutriCoach — Fait avec ❤️ au Le Wagon</p>
</footer>
