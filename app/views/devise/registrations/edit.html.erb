<div class="container d-flex justify-content-center align-items-center min-vh-100">
  <div
    class="card shadow-lg border-0 rounded-4 p-4 w-100"
    style="max-width:550px;"
  >
    <h2 class="text-center mb-4 fw-bold text-primary">
      Edit Profile
    </h2>

    <%= simple_form_for(resource,
        as: resource_name,
        url: registration_path(resource_name),
        html: { method: :put }) do |f| %>
      <%= f.error_notification %>

      <div class="form-inputs">
        <%= f.input :email,
            required: true,
            autofocus: true,
            input_html: {
              class: "form-control rounded-3"
            } %>

        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <div class="alert alert-warning rounded-3">
            Currently waiting confirmation for:
            <strong><%= resource.unconfirmed_email %></strong>
          </div>
        <% end %>

        <%= f.input :password,
            hint: "Leave blank if you don't want to change it",
            required: false,
            input_html: {
              autocomplete: "new-password",
              class: "form-control rounded-3"
            } %>

        <%= f.input :password_confirmation,
            required: false,
            input_html: {
              autocomplete: "new-password",
              class: "form-control rounded-3"
            } %>

        <%= f.input :current_password,
            hint: "Enter your current password to save changes",
            required: true,
            input_html: {
              autocomplete: "current-password",
              class: "form-control rounded-3"
            } %>
      </div>

      <div class="d-grid mt-4">
        <%= f.button :submit,
            "Update Profile",
            class: "btn btn-primary btn-lg rounded-3" %>
      </div>
    <% end %>

    <hr class="my-4">

    <div class="text-center">
      <h5 class="text-danger mb-3">
        Danger Zone
      </h5>

      <p class="text-muted">
        Permanently delete your account
      </p>

      <%= button_to "Cancel my account",
          registration_path(resource_name),
          method: :delete,
          data: {
            turbo_confirm: "Are you sure?"
          },
          class: "btn btn-outline-danger rounded-3" %>
    </div>

    <div class="text-center mt-4">
      <%= link_to "← Back",
          :back,
          class: "btn btn-secondary rounded-3" %>
    </div>
  </div>
</div>
