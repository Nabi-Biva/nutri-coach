<%= simple_form_for current_user.profile do |f| %>
  <%= f.input :sex,
      collection: ["Male", "Female", "Other"],
      prompt: "Select your sex" %>

  <%= f.input :birthday, as: :date %>

  <%= f.input :weight, as: :float,
      input_html: {
        placeholder: "Enter your weight (Ex: 64,5kg)", step: :any } %>


  <%= f.input :height,
      as: :float,
      input_html: {
        placeholder: "Enter your height (Ex: 1,8 m)",
        step: :any
      } %>

<%= f.input :imc %>

  <%= f.input :goal %>
  <%= f.input :allergy %>
  <%= f.input :lifestyle %>

<%= f.button :submit, current_user.profile.persisted? ? "Modify your profile" : "Create your profile", class: "btn btn-secondary" %><% end %>
