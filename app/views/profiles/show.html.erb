<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
      <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
        <!-- HEADER -->
        <div class="text-white text-center p-4" style="background-color: #2d6a4f;">
          <h1 class="fw-bold mb-1">
            <i class="fa-solid fa-user"></i>
            Mon Profile
          </h1>

          <p class="mb-0 opacity-75">
            Bienvenue <%= current_user.first_name %>
          </p>
        </div>

        <!-- BODY -->
        <div class="card-body p-4">
          <!-- SEX -->
          <div
            class="
              d-flex justify-content-between align-items-center
              border-bottom py-3
            "
          >
            <span class="fw-semibold">
              <i class="fa-solid fa-venus-mars me-2 text-secondary"></i>
              Sexe
            </span>

            <span class="badge bg-secondary fs-6 px-3 py-2 rounded-pill">
              <%= @profile.sex %>
            </span>
          </div>

          <!-- BIRTHDAY -->
          <div
            class="
              d-flex justify-content-between align-items-center
              border-bottom py-3
            "
          >
            <span class="fw-semibold">
              <i class="fa-solid fa-cake-candles me-2 text-secondary"></i>
              Né(e) le :
            </span>

<%= @profile.birthday&.strftime("%d/%m/%Y") %>
</div>

          <!-- WEIGHT -->
          <div
            class="
              d-flex justify-content-between align-items-center
              border-bottom py-3
            "
          >
            <span class="fw-semibold">
              <i class="fa-solid fa-weight-scale me-2 text-secondary"></i>
              Poids
            </span>

            <span><%= @profile.weight %> kg</span>
          </div>

          <!-- HEIGHT -->
          <div
            class="
              d-flex justify-content-between align-items-center
              border-bottom py-3
            "
          >
            <span class="fw-semibold">
              <i class="fa-solid fa-ruler-vertical me-2 text-secondary"></i>
              Taille
            </span>

            <span><%= @profile.height %> m</span>
          </div>

          <!-- BMI -->
          <div
            class="
              d-flex justify-content-between align-items-center
              border-bottom py-3
            "
          >
            <!-- LEFT -->
            <span class="fw-semibold">
              <i class="fa-solid fa-heart-pulse me-2 text-danger"></i>
              IMC
            </span>

            <!-- RIGHT -->
            <div class="text-end">
              <!-- SCORE -->
              <span class="badge bg-dark fs-6 px-3 py-2 rounded-pill">
                <%= @profile.imc.round(1) %>
              </span>

              <!-- INTERPRETATION -->
              <div class="mt-2">
                <span class="badg px-3 py-2 rounded-pill" style="background-color: <%= @profile.imc_color %>;">
                  <%= @profile.imc_interpretation %>
                </span>
              </div>

              <!-- INFO -->
              <p class="text-muted small mt-2 mb-0">
                IMC normal: 18,5 - 24,9
              </p>
            </div>
          </div>

          <!-- GOAL -->
          <div class="py-3 border-bottom">
            <p class="fw-semibold mb-2">
              <i class="fa-solid fa-bullseye me-2 text-secondary"></i>
              Objectif
            </p>

            <p class="text-muted mb-0">
              <%= @profile.goal %>
            </p>
          </div>

          <!-- ALLERGY -->
          <div class="py-3 border-bottom">
            <p class="fw-semibold mb-2">
              <i class="fa-solid fa-triangle-exclamation me-2 text-warning"></i>
              Allergies
            </p>

            <p class="text-muted mb-0">
              <%= @profile.allergy %>
            </p>
          </div>

          <!-- LIFESTYLE -->
          <div class="py-3">
            <p class="fw-semibold mb-2">
              <i class="fa-solid fa-leaf me-2 text-success"></i>
              style de vie
            </p>

            <p class="text-muted mb-0">
              <%= @profile.lifestyle %>
            </p>
          </div>
        </div>

        <!-- FOOTER -->
<div class="text-white text-center p-4" style="background-color: #2d6a4f;">
   <%= link_to "Edit profile",
              edit_profile_path(@profile),
              class: "btn btn-outline-light rounded-pill px-4 py-2" %>
        </div>
      </div>
    </div>
  </div>
</div>
```
